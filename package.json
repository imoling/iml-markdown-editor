{
  "name": "iml-markdown-editor",
  "version": "1.7.0",
  "description": "极简而极致的 Markdown 编辑器，支持双模编辑、PDF 导出与智能目录同步。",
  "main": "dist-electron/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"vite\" \"tsc -p electron/tsconfig.json -w\" \"(wait-on tcp:5173 || wait-on tcp:5174) && cross-env NODE_ENV=development ELECTRON_RUN_AS_NODE= electron .\"",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json && electron-builder",
    "build:mac": "tsc && vite build && tsc -p electron/tsconfig.json && electron-builder --mac",
    "build:win": "tsc && vite build && tsc -p electron/tsconfig.json && electron-builder --win"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "tiptap",
    "minimalist",
    "productivity"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-bubble-menu": "^2.11.5",
    "@tiptap/extension-code-block-lowlight": "^2.11.5",
    "@tiptap/extension-floating-menu": "^2.11.5",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.11.5",
    "@tiptap/extension-table-cell": "^2.11.5",
    "@tiptap/extension-table-header": "^2.11.5",
    "@tiptap/extension-table-row": "^2.11.5",
    "@tiptap/extension-task-item": "^2.11.5",
    "@tiptap/extension-task-list": "^2.11.5",
    "@tiptap/extension-text-align": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@uiw/react-codemirror": "^4.25.8",
    "electron-store": "^8.2.0",
    "katex": "^0.16.38",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.577.0",
    "marked": "^15.0.0",
    "mermaid": "^11.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/marked": "^5.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.imoling.markdown-editor",
    "productName": "iML Markdown Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "mac": {
      "icon": "assets/logo.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "assets/logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/logo.ico",
      "uninstallerIcon": "assets/logo.ico",
      "installerHeaderIcon": "assets/logo.ico",
      "installerSidebar": "assets/installerSidebar.png",
      "installerHeader": "assets/installerHeader.png",
      "createDesktopShortcut": "always",
      "shortcutName": "iML Markdown Editor",
      "allowElevation": true,
      "runAfterFinish": true
    }
  }
}
