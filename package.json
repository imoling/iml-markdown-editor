{
  "name": "iml-markdown-editor",
  "version": "1.5.0",
  "description": "极简而极致的 Markdown 编辑器，支持双模编辑、PDF 导出与智能目录同步。",
  "main": "dist-electron/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"vite\" \"tsc -p electron/tsconfig.json -w\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json && electron-builder"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "tiptap",
    "minimalist",
    "productivity"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@tiptap/extension-bubble-menu": "^3.20.1",
    "@tiptap/extension-code-block-lowlight": "^3.20.1",
    "@tiptap/extension-floating-menu": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-table": "^3.20.1",
    "@tiptap/extension-table-cell": "^3.20.1",
    "@tiptap/extension-table-header": "^3.20.1",
    "@tiptap/extension-table-row": "^3.20.1",
    "@tiptap/extension-task-item": "^3.20.1",
    "@tiptap/extension-task-list": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@uiw/react-codemirror": "^4.25.8",
    "electron-store": "^11.0.2",
    "katex": "^0.16.38",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/marked": "^5.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.imoling.markdown-editor",
    "productName": "iML Markdown Editor",
    "directories": {
      "output": "release"
    },
    "mac": {
      "icon": "assets/logo.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "assets/logo.icns",
      "target": "nsis"
    }
  }
}
